# ============================================
# SUPABASE CONFIGURATION
# ============================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key_here
VITE_SUPABASE_PROJECT_ID=your_project_id

# Service Role Key (Server-side only - DO NOT expose to client)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Shared secret for internal/scheduled edge functions
INTERNAL_FUNCTION_SECRET=your_internal_function_secret_here

# Vault Encryption Key (32+ characters for AES-256)
VAULT_ENCRYPTION_KEY=your_32_character_encryption_key_here

# ============================================
# TWILIO CONFIGURATION (SMS/Voice/WhatsApp)
# ============================================
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=whatsapp:+1234567890
TWILIO_API_KEY=your_twilio_api_key
TWILIO_API_SECRET=your_twilio_api_secret
TWILIO_TWIML_APP_SID=your_twiml_app_sid

# ============================================
# FACEBOOK/META CONFIGURATION
# ============================================
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
META_APP_SECRET=your_meta_app_secret
FACEBOOK_PAGE_ACCESS_TOKEN=your_page_access_token
VITE_FACEBOOK_APP_ID=your_facebook_app_id

# Meta Webhook Verification Token (you choose this value)
META_VERIFY_TOKEN=alcornexus

# ============================================
# GOOGLE OAUTH & CALENDAR
# ============================================
VITE_GOOGLE_CALENDAR_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
VITE_GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:8080/auth/google/callback
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_secret
OAuth_Client_ID=your_google_oauth_client_id

# ============================================
# EMAIL SERVICE (RESEND)
# ============================================
RESEND_API_KEY=your_resend_api_key

# ============================================
# AI SERVICES - GOOGLE GEMINI INTEGRATION
# ============================================
# Google Gemini API Key for direct AI integration (gemini-2.5-flash model)
GOOGLE_API_KEY=your_google_api_key_here
JAY_AI_WEBHOOK_SECRET=your_jay_ai_webhook_secret

# ============================================
# ELEVENLABS (TEXT-TO-SPEECH)
# ============================================
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# ============================================
# MONITORING & ANALYTICS (OPTIONAL)
# ============================================
# Error Tracking (Optional - can use internal dashboard)
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
VITE_SENTRY_ENV=development
VITE_SENTRY_DEV_ENABLED=false

# Analytics (Optional)
VITE_ANALYTICS_ENABLED=false
VITE_ANALYTICS_API_URL=

# Performance Monitoring (Optional)
VITE_ENABLE_PERFORMANCE_MONITORING=true
VITE_ENABLE_QUERY_MONITORING=true

# ============================================
# CACHING (OPTIONAL - UPSTASH REDIS)
# ============================================
VITE_UPSTASH_REDIS_REST_URL=
VITE_UPSTASH_REDIS_REST_TOKEN=

# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV=development
ENVIRONMENT=development
VITE_ENABLE_SOURCE_MAPS=true
VITE_DEBUG=false
VITE_API_TIMEOUT=30000

# ============================================
# SETUP INSTRUCTIONS
# ============================================
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Fill in your actual credentials
#
# 3. Never commit .env to git (already in .gitignore)
#
# 4. For production, set these in:
#    - Supabase Dashboard > Project Settings > Edge Functions > Secrets
#    - Vercel Dashboard > Project Settings > Environment Variables
#
# 5. Required vs Optional:
#    Required: Supabase, Vault Key
#    Optional: Twilio, Facebook, Google, AI services (features disabled if missing)
#
# 6. Security:
#    - Rotate secrets every 90 days (tracked in secret_rotation_tracking table)
#    - Use strong encryption key (32+ characters)
#    - Never share service role key
#
# For detailed setup, see: DEPLOYMENT.md

# Notes:
# - Copy this file to .env.local and fill in your values
# - Never commit .env.local with real secrets
# - Use different keys for staging/production environments
# - LOVABLE_API_KEY should only be used in server-side code (Edge Functions)
